# ── Supabase (REQUIRED) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT signing secret — from: Supabase Dashboard → Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Redis / Celery (REQUIRED) ─────────────────────────────────────────────────
# Local: redis://localhost:6379/0  |  Railway: automatically injected
REDIS_URL=redis://localhost:6379/0

# ── Anthropic (REQUIRED) ──────────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── App ───────────────────────────────────────────────────────────────────────
# Frontend URL used in Stripe redirect URLs and notification links
FRONTEND_URL=http://localhost:3000

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── Stripe (optional — disables billing if absent) ────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — from: Stripe Dashboard → Products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Email — Resend (optional) ─────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_...
# Optional — defaults to alerts@leaklock.io
# RESEND_FROM_EMAIL=alerts@yourdomain.com

# ── Email — SendGrid (optional, alternative to Resend) ───────────────────────
# SENDGRID_API_KEY=SG....
# SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# ── Email — SMTP (optional, fallback) ────────────────────────────────────────
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=yourpassword
# SMTP_FROM_EMAIL=alerts@yourdomain.com

# ── SMS — Twilio (optional) ───────────────────────────────────────────────────
# Found in: twilio.com/console
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+15555550100

# ── Slack alerts (optional) ───────────────────────────────────────────────────
# Found in: Slack → Apps → Incoming Webhooks → your webhook
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Upstash Redis (optional — for per-tenant rate limiting) ───────────────────
# Found in: console.upstash.com → your database → REST API
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# ── Voyage AI (optional — improves match accuracy with vector embeddings) ─────
# Found in: voyageai.com → API Keys
# VOYAGE_API_KEY=pa-...

# ── PostHog (optional — server-side analytics) ────────────────────────────────
# POSTHOG_API_KEY=phc_...

# ── Trigger.dev (optional — webhook ingestion with retries) ───────────────────
# Found in: app.trigger.dev → Project Settings → API keys
# TRIGGER_API_KEY=tr_...
# TRIGGER_API_URL=https://api.trigger.dev

# ── Webhook secrets (optional — enables HMAC signature validation) ────────────
# Generic webhook endpoint (/webhooks/generic)
# WEBHOOK_SECRET=your-hmac-secret

# CRM connector webhook secrets
# SERVICETITAN_WEBHOOK_SECRET=your-st-secret
# JOBBER_WEBHOOK_SECRET=your-jobber-secret
# HOUSECALLPRO_WEBHOOK_SECRET=your-hcp-secret

# ── Tuning (optional) ─────────────────────────────────────────────────────────
# Float 0-1: minimum similarity score to count as a match (default: 0.75)
# MATCH_THRESHOLD=0.75

# Integer cents: minimum leak amount to trigger an alert (default: 2500 = $25)
# ALERT_THRESHOLD_CENTS=2500

# Float 0-1: false-positive rate at which a PostHog alert fires (default: 0.05)
# FP_RATE_ALERT_THRESHOLD=0.05

# ── Supabase Edge Function secrets (set via Supabase Dashboard → Edge Functions → Secrets) ──
# These are NOT loaded from this file — set them in the Supabase dashboard or via:
#   supabase secrets set DEEPGRAM_API_KEY=...
#
# DEEPGRAM_API_KEY=...      # Used by process-voice edge function for audio transcription

# ── Dev / test ────────────────────────────────────────────────────────────────
# Set to "true" to bypass JWT auth in local development ONLY — never in prod
# SUPABASE_AUTH_BYPASS=true
